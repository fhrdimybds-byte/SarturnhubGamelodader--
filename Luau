-- Auto Farm Obby Hard ATUALIZADO (2026) - Detecta winpad automaticamente
-- Funciona mesmo se o obby atualizar (procura por "winpad", "end", "finish", "pad" ou plataformas altas)
-- Anti-detection: delays random, TP suave

local winPosCache = nil  -- Cache pra não procurar toda hora

local function findWinPad()
    if winPosCache then return winPosCache end
    
    local candidates = {}
    
    -- Procura nomes óbvios de winpad
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and (
            obj.Name:lower():find("win") or 
            obj.Name:lower():find("end") or 
            obj.Name:lower():find("finish") or 
            obj.Name:lower():find("pad") or 
            obj.Name:lower():find("checkpoint") or
            obj.Name:lower():find("obby")
        ) then
            table.insert(candidates, obj)
        end
    end
    
    -- Fallback: plataforma mais alta (Y > 200)
    local highestY = 0
    local highestObj = nil
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Position.Y > highestY and obj.Position.Y > 200 and obj.Size.Y > 4 then
            highestY = obj.Position.Y
            highestObj = obj
        end
    end
    
    if #candidates > 0 then
        local winObj = candidates[1]  -- Pega o primeiro encontrado
        winPosCache = winObj.Position + Vector3.new(math.random(-2,2), 5, math.random(-2,2))  -- Random offset anti-detect
        return winPosCache
    elseif highestObj then
        winPosCache = highestObj.Position + Vector3.new(math.random(-2,2), 5, math.random(-2,2))
        return winPosCache
    end
    
    return nil
end

